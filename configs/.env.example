# OpenRouter API 密钥
OPENROUTER_API_KEY=your_api_key_here

# Moonshot API 密钥（用于视频分析）
# 在 https://platform.moonshot.cn/ 获取
MOONSHOT_API_KEY=your_moonshot_api_key_here

# 默认使用的模型（kimi, kimi-vision, gemini-flash）
DEFAULT_MODEL=gemini-flash

# 最大视频文件大小（MB）
MAX_VIDEO_SIZE_MB=80

# API 请求超时时间（秒）
API_TIMEOUT_SECONDS=300

# 最大重试次数
MAX_RETRIES=3